# =============================================================================
# Authrex — example environment configuration
# =============================================================================
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#
# Three deployment modes:
#   1. LOCAL DEV  (default values below) — postgres + openrouter, mock TriZetto + mock Q
#   2. PUNE DEMO  (May 6) — flip LLM_PROVIDER=bedrock, set Bedrock + Guardrail vars
#   3. PRODUCTION (post-pilot) — set REDIS_URL, TRIZETTO_GATEWAY_URL, AMAZON_Q_*
# =============================================================================

# --- LLM provider ----------------------------------------------------------
LLM_PROVIDER=openrouter                      # local dev default; flip to "bedrock" on May 6 Pune
ANTHROPIC_API_KEY=                           # only needed if LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENROUTER_API_KEY=                          # only needed if LLM_PROVIDER=openrouter
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# --- AWS / Bedrock (production) -------------------------------------------
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-6-20251022-v1:0
BEDROCK_HAIKU_MODEL_ID=apac.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_GUARDRAIL_ID=                        # per-tenant; provisioned during onboarding (ops/multi-tenant/ONBOARDING.md)
BEDROCK_GUARDRAIL_VERSION=DRAFT
BEDROCK_KB_ID=                               # optional — leave empty if using Q Business

# --- GenAI Gateway (in-process governance) --------------------------------
GENAI_GATEWAY_ENABLED=true                   # leave true unless debugging the underlying client

# --- Database --------------------------------------------------------------
DATABASE_URL=postgresql://authrex:authrex@localhost:5432/authrex
# Pool sizing (per-pod). Defaults are 4/8 — see ops/k8s/config.yaml.
# DATABASE_POOL_MIN=4
# DATABASE_POOL_MAX=8

# --- Redis (multi-replica SSE pub/sub) ------------------------------------
# Empty = in-process pub/sub (single-replica dev). Set on prod with > 1 API replica.
REDIS_URL=

# --- Cognizant TriZetto AI Gateway (Aug 2025 launch; MCP-native) ---------
# Empty = in-process mock receiver at /api/v1/integrations/trizetto/_mock/inbox.
# Set both on prod to flip to live Gateway calls.
TRIZETTO_GATEWAY_URL=
TRIZETTO_GATEWAY_TOKEN=

# --- Amazon Q Business (alternative to Bedrock KB) ------------------------
# Empty = Bedrock KB / curated corpus. Set USE_AMAZON_Q=true + the IDs to flip.
USE_AMAZON_Q=false
AMAZON_Q_APPLICATION_ID=
AMAZON_Q_INDEX_ID=
AMAZON_Q_REGION=us-east-1

# --- Embeddings (pgvector dev path; production uses Bedrock Titan) -------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- App -------------------------------------------------------------------
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- Environment + safety enforcement -------------------------------------
# When set to "staging" or "production", the Settings model_validator
# fails-fast if any secret below is the dev default. Stays "dev" in
# local + hackathon-demo; flipped to "production" in real deploys.
ENVIRONMENT=dev

# --- Auth (JWT) -----------------------------------------------------------
# Dev default is fine for local; MUST rotate via AWS Secrets Manager in
# prod (the model_validator in app/config.py rejects boot otherwise).
JWT_SECRET=authrex-dev-secret-change-in-prod-via-env-CmDbYVQrV3
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080                     # 7 days for demo convenience

# --- Demo / seed users ----------------------------------------------------
# Bootstraps three demo accounts (admin/reviewer/coordinator) on first
# boot. MUST be overridden in staging/production (validator enforces it).
DEMO_USER_PASSWORD=authrex2026

# --- Flags ----------------------------------------------------------------
USE_BEDROCK_KB=false
SEED_ON_BOOT=false

# --- MCP server -----------------------------------------------------------
# Optional shared-secret bearer token for /mcp. Empty = open (demo). Set in prod.
MCP_AUTH_TOKEN=

# --- HITL gate ------------------------------------------------------------
# 0.0 in dev/demo so every case runs the full DAG. 0.75 in prod (CA SB 1120 conservative).
HITL_CONFIDENCE_THRESHOLD=0.0
